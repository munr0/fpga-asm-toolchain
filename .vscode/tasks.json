{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Assemble (a51)",
            "type": "shell",
            "command": "${workspaceFolder}/Call51/Bin/a51.exe",
            "args": [
                "-l",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Flash to DE0-CV (JTAG)",
            "type": "shell",
            "command": "${env:QUARTUS_ROOTDIR}/bin64/quartus_stp.exe",
            "args": [
                "-t",
                "${workspaceFolder}/Load_Script.tcl",
                "${fileBasenameNoExtension}.hex"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build & Flash",
            "dependsOn": [
                "Assemble (a51)",
                "Flash to DE0-CV (JTAG)"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
